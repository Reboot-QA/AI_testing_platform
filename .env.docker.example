# Docker 一键部署环境变量
# 用法: ./linux-deploy.sh init-env  （推荐，会自动写入默认 MySQL 密码到 .env.docker）
# 或: cp .env.docker.example .env.docker && ./linux-deploy.sh up

# 对外端口
HTTP_PORT=5173
BACKEND_PORT=8000

# MySQL（init-env / 首次部署时由 linux-deploy.sh 自动写入默认密码；勿对公网暴露 3306）
# MYSQL_PUBLISH_HOST=127.0.0.1  仅本机/SSH 隧道可连（推荐）
# MYSQL_PUBLISH_HOST=0.0.0.0      对公网暴露（高风险，易被勒索扫描）
MYSQL_PUBLISH_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-password
DB_HOST=mysql
DB_PORT=3306
DB_USER=ai_testcase
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=ai_testcase

# 应用
SECRET_KEY=change-this-to-a-random-secret-key
APP_NAME=AI质量平台

# LLM（OpenAI 兼容 API）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MOCK_MODE=true
AI_GENERATE_BATCH_SIZE=8
AI_GENERATE_CONCURRENCY=4

# 日志（Docker 与 Promtail 共用宿主机目录，确保 Loki 能采集到）
HOST_LOG_DIR=./.deploy/logs
LOG_DIR=/app/logs

# Grafana + Loki（启用 monitoring profile 时生效）
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_ROOT_URL=http://127.0.0.1:5173/api/v1/logs/grafana
# 后端容器访问独立 monitoring 栈（Linux 需配合 docker-compose extra_hosts）
GRAFANA_URL=http://host.docker.internal:3000
LOKI_URL=http://host.docker.internal:3100
# 浏览器访问地址（留空时由后端根据访问 IP 自动替换 grafana/loki 内网主机名）
GRAFANA_PUBLIC_URL=
LOKI_PUBLIC_URL=
