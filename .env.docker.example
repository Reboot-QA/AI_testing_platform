# Docker 一键部署环境变量
# 用法: cp .env.docker.example .env.docker && ./docker/deploy.sh up

# 对外端口
HTTP_PORT=5173
BACKEND_PORT=8000

# MySQL
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=123456
DB_HOST=mysql
DB_PORT=3306
DB_USER=ai_testcase
DB_PASSWORD=123456
DB_NAME=ai_testcase

# 应用
SECRET_KEY=change-this-to-a-random-secret-key
APP_NAME=AI质量平台

# LLM（OpenAI 兼容 API）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MOCK_MODE=true
AI_GENERATE_BATCH_SIZE=8
AI_GENERATE_CONCURRENCY=4

# 日志
LOG_DIR=/app/logs

# Grafana + Loki（启用 monitoring profile 时生效）
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_ROOT_URL=http://127.0.0.1:3000
GRAFANA_PUBLIC_URL=
LOKI_PUBLIC_URL=
