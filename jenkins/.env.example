# Jenkins CI/CD 环境变量（复制为 jenkins/.env 后修改）
# 用法: cp .env.example .env && vi .env && docker compose --env-file .env up -d --build

# 应用部署目录（需与 install-server.sh / linux-deploy.sh 一致）
APP_DIR=/opt/AI_testing_platform

# Jenkins 对外端口
JENKINS_HTTP_PORT=8080
JENKINS_AGENT_PORT=50000

# Jenkins 登录账号（必填，勿使用弱密码）
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me-jenkins-password

# Jenkins 对外访问地址（用于 JCasC location，填公网 URL）
JENKINS_URL=http://127.0.0.1:8080/

# GitHub Webhook Secret（与 GitHub 仓库 Webhook 配置一致）
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# 宿主机 docker 组 ID（install.sh 会自动检测）
# DOCKER_GID=999
