pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 45, unit: 'MINUTES')
        skipDefaultCheckout(true)
    }

    environment {
        APP_DIR = "${env.APP_DIR ?: '/opt/AI_testing_platform'}"
        ENV_FILE = "${env.ENV_FILE ?: '/opt/AI_testing_platform/.env.docker'}"
    }

    triggers {
        githubPush()
        pollSCM('H/5 * * * *')
    }

    stages {
        stage('一键发版') {
            steps {
                sh '''
                    set -e
                    export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
                    APP_DIR="${APP_DIR:-/opt/AI_testing_platform}"
                    ENV_FILE="${ENV_FILE:-/opt/AI_testing_platform/.env.docker}"
                    UPDATE_SCRIPT="${APP_DIR}/update.sh"
                    DEPLOY_SCRIPT="${APP_DIR}/jenkins/scripts/deploy.sh"

                    git config --global --add safe.directory "${APP_DIR}" 2>/dev/null || true
                    test -f "${ENV_FILE}" || { echo "缺少 ${ENV_FILE}"; exit 1; }
                    test -S /var/run/docker.sock || { echo "未挂载 docker.sock"; exit 1; }

                    if [ -f "${UPDATE_SCRIPT}" ]; then
                      sed -i 's/\\r$//' "${UPDATE_SCRIPT}" 2>/dev/null || true
                      chmod +x "${UPDATE_SCRIPT}" 2>/dev/null || true
                      bash "${UPDATE_SCRIPT}"
                    elif [ -f "${DEPLOY_SCRIPT}" ]; then
                      sed -i 's/\\r$//' "${DEPLOY_SCRIPT}" 2>/dev/null || true
                      chmod +x "${DEPLOY_SCRIPT}" 2>/dev/null || true
                      bash "${DEPLOY_SCRIPT}"
                    else
                      echo "错误: 找不到发版脚本"
                      echo "请在服务器执行:"
                      echo "  cd ${APP_DIR} && git pull && chmod +x update.sh jenkins/scripts/deploy.sh"
                      exit 1
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo '发版成功：已执行 update.sh（git pull + 重新部署）'
        }
        failure {
            echo '发版失败，请在服务器查看: docker logs ai-platform-backend --tail=80'
        }
    }
}
