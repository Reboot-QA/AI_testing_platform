# 应用配置
APP_NAME=AI质量平台
SECRET_KEY=change-this-to-a-random-secret-key

# MySQL 数据库（推荐：使用 DB_* 参数；也可直接设置 DATABASE_URL 覆盖）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password-here
DB_NAME=ai_testcase
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/ai_testcase?charset=utf8mb4

# LLM 配置（OpenAI 兼容 API）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini

# 未配置 API Key 时使用 Mock 模式生成示例用例
LLM_MOCK_MODE=true

# AI 用例生成性能（23 个需求默认约 23 次 API 调用，并发可显著加速）
AI_GENERATE_BATCH_SIZE=8
AI_GENERATE_CONCURRENCY=4

# 日志目录（相对项目根目录，默认 .deploy/logs）
LOG_DIR=.deploy/logs

# Grafana + Loki 外部日志平台（需 ./deploy.sh monitoring start）
GRAFANA_ENABLED=true
GRAFANA_URL=
GRAFANA_PORT=3000
# 外网访问地址（可选；不填则根据浏览器访问域名自动替换 127.0.0.1）
GRAFANA_PUBLIC_URL=http://38.12.6.230:3000
GRAFANA_EMBED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
LOKI_URL=
LOKI_PORT=3100
LOKI_PUBLIC_URL=http://38.12.6.230:3100
